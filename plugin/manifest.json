{
  "manifest_version": 3,
  "name": "Seedance Cookie Importer",
  "version": "1.0.0",
  "description": "从 Dreamina (capcut.com) 提取 SessionID 和 Cookies，一键导入到 Seedance 平台",
  "permissions": ["cookies", "storage", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Seedance Cookie Importer",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
